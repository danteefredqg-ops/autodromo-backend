# Variables de entorno — Railway las inyecta automáticamente al conectar MySQL
MYSQLHOST=containers-us-west-xxx.railway.app
MYSQLUSER=root
MYSQLPASSWORD=tu_password
MYSQLDATABASE=railway
MYSQLPORT=3306

# JWT
JWT_SECRET=cambia_esto_en_produccion_con_un_string_largo_y_aleatorio

# CORS — URL de tu GitHub Pages frontend
FRONTEND_URL=https://tu-usuario.github.io

# Fotos de perfil — ruta de un Railway Volume montado al servicio backend.
# Sin esto, las fotos se guardan en una carpeta local que Railway borra en cada deploy.
UPLOADS_DIR=/data/uploads

# Correo (Resend) — recuperación de contraseña de pilotos
# Consigue tu API key gratis en https://resend.com (sin dominio verificado,
# los correos solo llegan a la cuenta dueña de la API key — sirve para probar,
# no para producción real hasta verificar un dominio propio ahí mismo).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Autódromo Monterrey <onboarding@resend.dev>
